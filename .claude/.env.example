# CraveMode Engine - API Keys
# Copy this to .env and fill in your keys:
#   cp .env.example .env
# OR: leave empty to inherit from parent creative-engine-template/.claude/.env

# Google AI Studio (default for images + Veo 3.1 videos)
GOOGLE_API_KEY=your_google_api_key_here

# Kie AI (backup image gen + Kling/Sora video gen + file hosting)
KIE_API_KEY=your_kie_api_key_here

# Airtable
AIRTABLE_API_KEY=your_airtable_pat_here
AIRTABLE_BASE_ID=appxOWa96FjSvk6Yn

# WaveSpeed AI (optional backup video provider)
WAVESPEED_API_KEY=your_wavespeed_key_here
